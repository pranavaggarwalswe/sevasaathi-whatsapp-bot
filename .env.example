# Copy this file to .env (or set these in your hosting dashboard) and fill in real values.
# NEVER commit the real .env to git.

# Any random string you invent — must match what you type in Meta's webhook setup screen
VERIFY_TOKEN=my_secret_verify_token_123

# Permanent access token from Meta (System User token) — see SETUP.md step 6
WHATSAPP_TOKEN=

# Phone number ID (NOT the phone number itself) from Meta dashboard > WhatsApp > API Setup
PHONE_NUMBER_ID=

# Your personal WhatsApp number for order alerts, country code + number, digits only
ADMIN_NUMBER=91XXXXXXXXXX

BUSINESS_NAME=SevaSaathi
UPI_ID=yourname@upi
